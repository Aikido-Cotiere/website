[{"data":1,"prerenderedAt":461},["ShallowReactive",2],{"settings":3,"aikido":76},{"id":4,"uid":5,"url":5,"type":6,"href":7,"tags":8,"first_publication_date":9,"last_publication_date":10,"slugs":11,"linked_documents":13,"lang":14,"alternate_languages":15,"data":16},"af9qgBAAACcASJmy",null,"settings","https:\u002F\u002Faikido-traditionnel-cotiere.cdn.prismic.io\u002Fapi\u002Fv2\u002Fdocuments\u002Fsearch?ref=akTQhxIAACcAR_CM&q=%5B%5B%3Ad+%3D+at%28document.id%2C+%22af9qgBAAACcASJmy%22%29+%5D%5D",[],"2026-05-09T17:11:04+0000","2026-07-01T07:15:07+0000",[12],"menu-principal",[],"fr-fr",[],{"site_title":17,"site_description":18,"site_image":19,"navigation":29},"Aïkido Traditionnel de la Cotière","Le site du Dojo d'aïkido de dagneux",{"dimensions":20,"alt":5,"copyright":5,"url":23,"id":24,"edit":25},{"width":21,"height":22},131,184,"https:\u002F\u002Fimages.prismic.io\u002Faikido-traditionnel-cotiere\u002Faf9VUaYofJOwHCJZ_main-logo.jpg?auto=format,compress","af9VUaYofJOwHCJZ",{"x":26,"y":26,"zoom":27,"background":28},0,1,"transparent",[30,43,54,65],{"id":31,"type":32,"tags":33,"lang":14,"slug":34,"first_publication_date":35,"last_publication_date":36,"url":37,"link_type":38,"key":39,"isBroken":40,"text":41,"variant":42},"af9xqhAAACgASKPZ","index",[],"accueil","2026-05-09T17:41:10+0000","2026-06-25T21:16:02+0000","\u002F","Document","8ccaa39a-debf-4883-93f1-156ce0bc7681",false,"Le Dojo","Lien",{"id":44,"type":45,"tags":46,"lang":14,"slug":47,"first_publication_date":48,"last_publication_date":49,"uid":50,"url":51,"link_type":38,"key":52,"isBroken":40,"text":53,"variant":42},"agL_7RAAACgATcrb","focuses",[],"laikido","2026-05-12T10:29:03+0000","2026-05-13T14:20:54+0000","aikido","\u002Ffocus\u002Faikido","2c918af7-a31f-4d87-a906-63d0c3dd8d72","L'Aïkido",{"id":55,"type":56,"tags":57,"lang":14,"slug":58,"first_publication_date":59,"last_publication_date":60,"uid":61,"url":62,"link_type":38,"key":63,"isBroken":40,"text":64,"variant":42},"agMF8RAAANw7TdUG","standard",[],"cours-dessai-sans-engagement","2026-05-12T10:51:05+0000","2026-07-01T07:53:01+0000","essai-gratuit","\u002Fessai-gratuit","eb53ebaf-7be1-48a6-aca2-8a14b526b244","Essai gratuit",{"id":66,"type":56,"tags":67,"lang":14,"slug":68,"first_publication_date":69,"last_publication_date":70,"uid":71,"url":72,"link_type":38,"key":73,"isBroken":40,"text":74,"variant":75},"aiEb6BYAAC0AdvTJ",[],"inscrivez-vous-","2026-06-04T06:32:33+0000","2026-07-01T08:32:07+0000","inscriptions","\u002Finscriptions","b4d404eb-b90c-4329-8c85-e6e98b411fb2","Inscriptions","Bouton",{"id":44,"uid":50,"url":51,"type":45,"href":77,"tags":78,"first_publication_date":48,"last_publication_date":49,"slugs":79,"linked_documents":80,"lang":14,"alternate_languages":81,"data":82},"https:\u002F\u002Faikido-traditionnel-cotiere.cdn.prismic.io\u002Fapi\u002Fv2\u002Fdocuments\u002Fsearch?ref=akTQhxIAACcAR_CM&q=%5B%5B%3Ad+%3D+at%28document.id%2C+%22agL_7RAAACgATcrb%22%29+%5D%5D",[],[47],[],[],{"title":83,"description":89,"cover":94,"slices":101,"meta_title":5,"meta_description":5,"meta_image":460},[84],{"type":85,"text":86,"spans":87,"direction":88},"heading1","L'aïkido",[],"ltr",[90],{"type":91,"text":92,"spans":93,"direction":88},"paragraph","Ici, pas de compétition. Nous cultivons le respect, l'entraide et la recherche de l'équilibre. Inspirés par l'enseignement de notre regretté Sensei Jimmy, nous perpétuons une tradition où chaque pratiquant progresse à son rythme.",[],{"dimensions":95,"alt":5,"copyright":5,"url":98,"id":99,"edit":100},{"width":96,"height":97},2816,1536,"https:\u002F\u002Fimages.prismic.io\u002Faikido-traditionnel-cotiere\u002FagMA6aYofJOwHHj0_Gemini_Generated_Image_ap8q70ap8q70ap8q.png?auto=format,compress","agMA6aYofJOwHHj0",{"x":26,"y":26,"zoom":27,"background":28},[102,143,352],{"variation":103,"version":104,"items":105,"primary":106,"id":141,"slice_type":142,"slice_label":5},"default","initial",[],{"anchor":5,"title":107,"sub_title":110,"content":122,"image":129,"liens":130,"details":140,"iframe":5},[108],{"type":85,"text":53,"spans":109,"direction":88},[],[111],{"type":112,"text":113,"spans":114,"direction":88},"heading2","Un art ancestral et des valeurs fortes",[115,119],{"start":116,"end":117,"type":118},3,16,"em",{"start":120,"end":121,"type":118},24,38,[123,126],{"type":91,"text":124,"spans":125,"direction":88},"C'est un art martial fondé au Japon dans la première moitié du XXe siècle par Maître UESHIBA Morihei.",[],{"type":91,"text":127,"spans":128,"direction":88},"Bien qu'il soit une redoutable technique de combat, l'Aïkido ne vise pas la destruction de l'autre, mais tend au contraire à permettre aux pratiquants de se construire eux-mêmes, en prenant conscience de leurs capacités comme de leurs limites. L'Aïkido permet de développer sa perception intuitive de l'attaque et, sans jamais s'y opposer, d'utiliser la force contenue dans cette attaque afin qu'elle se retourne contre l'attaquant lui-même.",[],{},[131,136],{"link_type":132,"key":133,"url":134,"text":135,"variant":75},"Web","171b3f4d-e42f-483f-9b89-f42653d15b21","#regles","Règles de conduite",{"link_type":132,"key":137,"url":138,"text":139,"variant":75},"cf9a8e8c-f1a2-4ecd-8b6b-292105b62392","#tenue","La tenue standard",[],"focus_content$d6ce395c-7348-40c6-b7a1-33e27b84567a","focus_content",{"variation":103,"version":104,"items":144,"primary":145,"id":351,"slice_type":142,"slice_label":5},[],{"anchor":146,"title":147,"sub_title":151,"content":157,"image":164,"liens":171,"details":172,"iframe":5},"regles",[148],{"type":85,"text":149,"spans":150,"direction":88},"Les règles de conduite dans un dojo",[],[152],{"type":112,"text":149,"spans":153,"direction":88},[154],{"start":155,"end":156,"type":118},4,22,[158,161],{"type":91,"text":159,"spans":160,"direction":88},"Dans le cas où il n'y a aucune marque spécialisée, le kamiza se trouve à l'opposé de l'entrée. Le fond de la pièce ou de la maison est d'un rang plus élevé que l'entrée. Le côté gauche, vu du kamiza, est le côté le plus honorifique.",[],{"type":91,"text":162,"spans":163,"direction":88},"En Europe, une photo de O Senseï orne le kamiza et symbolise la transmission de l'enseignement.",[],{"dimensions":165,"alt":5,"copyright":5,"url":168,"id":169,"edit":170},{"width":166,"height":167},532,422,"https:\u002F\u002Fimages.prismic.io\u002Faikido-traditionnel-cotiere\u002Faf9VhaYofJOwHCJa_dojo.jpg?auto=format,compress","af9VhaYofJOwHCJa",{"x":26,"y":26,"zoom":27,"background":28},[],[173,191,204,217,230,243,256,269,285,298,312,325,338],{"content_title":174,"content_punchline":180,"content_body":185,"content_image":189,"content_link":190},[175],{"type":176,"text":177,"spans":178,"direction":88},"heading3","1",[179],{"start":26,"end":27,"type":118},[181],{"type":182,"text":183,"spans":184,"direction":88},"heading4","Respectez vos instruments de travail",[],[186],{"type":91,"text":187,"spans":188,"direction":88},"le Gi (tenue d'entraînement) doit être propre et en bon étatles armes doivent être rangées lorsqu'elles ne sont pas utilisées",[],{},[],{"content_title":192,"content_punchline":197,"content_body":201,"content_image":202,"content_link":203},[193],{"type":176,"text":194,"spans":195,"direction":88},"2",[196],{"start":26,"end":27,"type":118},[198],{"type":182,"text":199,"spans":200,"direction":88},"Respectez vos partenaires en veillant à votre propreté corporelle, et à la longueur des ongles des mains et des pieds, avant de monter sur le tatami",[],[],{},[],{"content_title":205,"content_punchline":210,"content_body":214,"content_image":215,"content_link":216},[206],{"type":176,"text":207,"spans":208,"direction":88},"3",[209],{"start":26,"end":27,"type":118},[211],{"type":182,"text":212,"spans":213,"direction":88},"Ne vous servez jamais d'un Gi ou d'armes qui ne vous appartiennent pas",[],[],{},[],{"content_title":218,"content_punchline":223,"content_body":227,"content_image":228,"content_link":229},[219],{"type":176,"text":220,"spans":221,"direction":88},"4",[222],{"start":26,"end":27,"type":118},[224],{"type":182,"text":225,"spans":226,"direction":88},"En entrant dans le dojo et en en sortant, vous devez saluer",[],[],{},[],{"content_title":231,"content_punchline":236,"content_body":240,"content_image":241,"content_link":242},[232],{"type":176,"text":233,"spans":234,"direction":88},"5",[235],{"start":26,"end":27,"type":118},[237],{"type":182,"text":238,"spans":239,"direction":88},"En montant sur le tatami et en le quittant, vous devez saluer",[],[],{},[],{"content_title":244,"content_punchline":249,"content_body":253,"content_image":254,"content_link":255},[245],{"type":176,"text":246,"spans":247,"direction":88},"6",[248],{"start":26,"end":27,"type":118},[250],{"type":182,"text":251,"spans":252,"direction":88},"Saluez toujours en direction du kamiza et du portrait de O SenseÏ",[],[],{},[],{"content_title":257,"content_punchline":262,"content_body":266,"content_image":267,"content_link":268},[258],{"type":176,"text":259,"spans":260,"direction":88},"7",[261],{"start":26,"end":27,"type":118},[263],{"type":182,"text":264,"spans":265,"direction":88},"Quelques minutes avant l'entraînement, vous devez y être préparé, assis en seiza, tous sur une même ligne, et dans une posture de méditation. Ces quelques minutes permettent à votre esprit de faire le vide, de se débarrasser des problèmes de la journée et préparent à l'étude.",[],[],{},[],{"content_title":270,"content_punchline":275,"content_body":279,"content_image":283,"content_link":284},[271],{"type":176,"text":272,"spans":273,"direction":88},"8",[274],{"start":26,"end":27,"type":118},[276],{"type":182,"text":277,"spans":278,"direction":88},"Le cours commence et se termine par une cérémonie formelle.",[],[280],{"type":91,"text":281,"spans":282,"direction":88},"C'est le professeur qui donne le signal du salut et dans un salut correct, l'élève s'appliquera à ne relever la tête qu'après son instructeurIl est essentiel d'être à l'heure pour y participer ; si vous arrivez en retard, vous devez attendre assis à côté du tatami jusqu'à ce que l'enseignant vous fasse signe de vous joindre au cours. Saluez-le à genoux en montant sur le tapis. Veillez aussi à ne pas perturber le cours",[],{},[],{"content_title":286,"content_punchline":291,"content_body":295,"content_image":296,"content_link":297},[287],{"type":176,"text":288,"spans":289,"direction":88},"9",[290],{"start":26,"end":27,"type":118},[292],{"type":182,"text":293,"spans":294,"direction":88},"La façon correcte de s'asseoir sur le tatami est la position en seiza. Mais si vous êtes blessé au genou, vous pouvez vous asseoir en tailleur. N'allongez jamais les jambes et ne vous adossez pas au mur ou à un poteau. Vous devez être disponible à chaque instant.",[],[],{},[],{"content_title":299,"content_punchline":305,"content_body":309,"content_image":310,"content_link":311},[300],{"type":176,"text":301,"spans":302,"direction":88},"10",[303],{"start":26,"end":304,"type":118},2,[306],{"type":182,"text":307,"spans":308,"direction":88},"Ne quittez pas le tatami pendant l'entraînement sauf en cas de blessure ou de malaise et en avertissant l'enseignant.",[],[],{},[],{"content_title":313,"content_punchline":318,"content_body":322,"content_image":323,"content_link":324},[314],{"type":176,"text":315,"spans":316,"direction":88},"11",[317],{"start":26,"end":304,"type":118},[319],{"type":182,"text":320,"spans":321,"direction":88},"Quand l'instructeur montre une technique, vous devez rester assis en seiza et regarder attentivement, en veillant à ne pas tourner le dos au kamiza. Après la démonstration,saluez l'instructeur, puis saluez votre partenaire et commencez à travailler.",[],[],{},[],{"content_title":326,"content_punchline":331,"content_body":335,"content_image":336,"content_link":337},[327],{"type":176,"text":328,"spans":329,"direction":88},"12",[330],{"start":26,"end":304,"type":118},[332],{"type":182,"text":333,"spans":334,"direction":88},"Dès que la fin d'une technique est annoncée, arrêtez immédiatement votre mouvement, saluez votre partenaire et rejoignez les autres pratiquants assis en ligne.",[],[],{},[],{"content_title":339,"content_punchline":344,"content_body":348,"content_image":349,"content_link":350},[340],{"type":176,"text":341,"spans":342,"direction":88},"13",[343],{"start":26,"end":304,"type":118},[345],{"type":182,"text":346,"spans":347,"direction":88},"Ne restez jamais debout sur le tapis sans travailler. S'il le faut, restez en seiza en attendant votre tour.",[],[],{},[],"focus_content$b410109d-b365-4119-a1e9-3e6d0aa71ff8",{"variation":103,"version":104,"items":353,"primary":354,"id":459,"slice_type":142,"slice_label":5},[],{"anchor":355,"title":356,"sub_title":359,"content":360,"image":364,"liens":369,"details":370,"iframe":5},"tenue",[357],{"type":85,"text":139,"spans":358,"direction":88},[],[],[361],{"type":91,"text":362,"spans":363,"direction":88},"Avant d'acheter un équipement quelconque, demandez conseil à votre sensei ou aux uchi-deshis (certains distributeurs consentent des remises aux adhérents du dojo).",[],{"dimensions":365,"alt":5,"copyright":5,"url":366,"id":367,"edit":368},{"width":96,"height":97},"https:\u002F\u002Fimages.prismic.io\u002Faikido-traditionnel-cotiere\u002FagRkbqYofJOwHLjT_Gemini_Generated_Image_gsw3rdgsw3rdgsw3.png?auto=format,compress","agRkbqYofJOwHLjT",{"x":26,"y":26,"zoom":27,"background":28},[],[371,390,419,441],{"content_title":372,"content_punchline":378,"content_body":379,"content_image":383,"content_link":389},[373],{"type":176,"text":374,"spans":375,"direction":88},"Le keikogi",[376],{"start":116,"end":377,"type":118},10,[],[380],{"type":91,"text":381,"spans":382,"direction":88},"Souvent improprement appelé kimono, c'est le vêtement de base de l'aïkidoka. Autrefois, ces vêtements constituaient les dessous des japonais; le keikogi se porte donc sans t-shirt, sauf bien entendu pour les femmes.",[],{"dimensions":384,"alt":5,"copyright":5,"url":385,"id":367,"edit":386},{"width":96,"height":97},"https:\u002F\u002Fimages.prismic.io\u002Faikido-traditionnel-cotiere\u002FagRkbqYofJOwHLjT_Gemini_Generated_Image_gsw3rdgsw3rdgsw3.png?auto=format%2Ccompress&rect=959%2C258%2C939%2C512&w=2816&h=1536",{"x":387,"y":388,"zoom":116,"background":28},959,258,[],{"content_title":391,"content_punchline":397,"content_body":398,"content_image":402,"content_link":409},[392],{"type":176,"text":393,"spans":394,"direction":88},"Le hakama",[395],{"start":116,"end":396,"type":118},9,[],[399],{"type":91,"text":400,"spans":401,"direction":88},"C'est un pantalon large de couleur noire ou bleu. Le port du hakama est accordé par le professeur à l'aïkidoka qui a atteint un certain niveau de pratique.",[],{"dimensions":403,"alt":5,"copyright":5,"url":404,"id":367,"edit":405},{"width":96,"height":97},"https:\u002F\u002Fimages.prismic.io\u002Faikido-traditionnel-cotiere\u002FagRkbqYofJOwHLjT_Gemini_Generated_Image_gsw3rdgsw3rdgsw3.png?auto=format%2Ccompress&rect=636%2C613%2C1514%2C826&w=2816&h=1536",{"x":406,"y":407,"zoom":408,"background":28},636,613,1.8600000000000003,[410],{"id":411,"type":45,"tags":412,"lang":14,"slug":413,"first_publication_date":414,"last_publication_date":415,"uid":413,"url":416,"link_type":38,"key":417,"isBroken":40,"text":418,"variant":42},"agRmOBAAANw7T99e",[],"le-hakama","2026-05-13T11:57:46+0000","2026-05-13T12:27:15+0000","\u002Ffocus\u002Fle-hakama","c4bf488f-49b1-4c45-8401-fb087d09c2e5","En savoir plus sur le hakama",{"content_title":420,"content_punchline":426,"content_body":427,"content_image":431,"content_link":440},[421],{"type":176,"text":422,"spans":423,"direction":88},"Le Obi",[424],{"start":116,"end":425,"type":118},6,[],[428],{"type":91,"text":429,"spans":430,"direction":88},"C'est une ceinture large utilisée principalement par les pratiquants d'aïkido ou de kendo. Elle facilite le port du hakama.",[],{"dimensions":432,"alt":5,"copyright":5,"url":435,"id":367,"edit":436},{"width":433,"height":434},400,100,"https:\u002F\u002Fimages.prismic.io\u002Faikido-traditionnel-cotiere\u002FagRkbqYofJOwHLjT_Gemini_Generated_Image_gsw3rdgsw3rdgsw3.png?auto=format%2Ccompress&rect=980%2C611%2C939%2C235&w=400&h=100",{"x":437,"y":438,"zoom":439,"background":28},980,611,2.9989350372736956,[],{"content_title":442,"content_punchline":447,"content_body":448,"content_image":452,"content_link":458},[443],{"type":176,"text":444,"spans":445,"direction":88},"Les Zooris",[446],{"start":155,"end":377,"type":118},[],[449],{"type":91,"text":450,"spans":451,"direction":88},"Pour des raisons d'hygiène, le trajet du vestiaire au tatami ne se fait pas pieds-nus.",[],{"dimensions":453,"alt":5,"copyright":5,"url":454,"id":367,"edit":455},{"width":433,"height":434},"https:\u002F\u002Fimages.prismic.io\u002Faikido-traditionnel-cotiere\u002FagRkbqYofJOwHLjT_Gemini_Generated_Image_gsw3rdgsw3rdgsw3.png?auto=format%2Ccompress&rect=913%2C1301%2C939%2C235&w=400&h=100",{"x":456,"y":457,"zoom":439,"background":28},913,1301,[],"focus_content$5111929d-d418-4a2e-898d-5f946b2bf055",{},1782895182604]