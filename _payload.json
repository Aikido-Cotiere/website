text":124,"spans":125,"direction":87},"Nous accueillons tous ceux qui souhaitent pratiquer avec nous cet art ancestral.",[],[127,149,191,216],{"title":128,"body":133,"image":140,"is_wide":40},[129],{"type":130,"text":131,"spans":132,"direction":87},"heading3","De tous niveaux",[],[134,137],{"type":90,"text":135,"spans":136,"direction":87},"Tous les aïkidokas du dojo pratiquent ensemble. ",[],{"type":90,"text":138,"spans":139,"direction":87},"Ainsi, chacun, qu'il soit débutant ou plus gradé, enrichit son expérience au contact de l'autre.",[],{"dimensions":141,"alt":5,"copyright":5,"url":144,"id":145,"edit":146},{"width":142,"height":143},240,144,"https:\u002F\u002Fimages.prismic.io\u002Faikido-traditionnel-cotiere\u002FagD1CqYofJOwHC2-_38f9e50d-0f99-4915-a3bb-ed75ddaf9e18.png?auto=format%2Ccompress&rect=241%2C0%2C1019%2C611&w=240&h=144","agD1CqYofJOwHC2-",{"x":147,"y":26,"zoom":148,"background":28},241,1.5699999999999998,{"title":150,"body":154,"image":183,"is_wide":190},[151],{"type":130,"text":152,"spans":153,"direction":87},"Adultes et ados de +14 ans",[],[155,161,167,172],{"type":90,"text":156,"spans":157,"direction":87},"Deux séances par semaine :",[158],{"start":26,"end":159,"type":160},4,"strong",{"type":90,"text":162,"spans":163,"direction":87},"- Le LUNDI (20h00-22h00) et ",[164],{"start":165,"end":166,"type":160},5,10,{"type":90,"text":168,"spans":169,"direction":87},"- Le MERCREDI (19h30-22h00).",[170],{"start":165,"end":171,"type":160},13,{"type":90,"text":173,"spans":174,"direction":87},"De septembre à mi-juillet (sauf pendant les vacances de Noël).",[175,178,180],{"start":176,"end":177,"type":160},3,12,{"start":119,"end":179,"type":160},25,{"start":181,"end":182,"type":121},27,60,{"dimensions":184,"alt":5,"copyright":5,"url":186,"id":187,"edit":188},{"width":185,"height":143},552,"https:\u002F\u002Fimages.prismic.io\u002Faikido-traditionnel-cotiere\u002Faf9VjaYofJOwHCJi_stagebourg2017.jpg?auto=format%2Ccompress&rect=0%2C77%2C968%2C253&w=552&h=144","af9VjaYofJOwHCJi",{"x":26,"y":189,"zoom":27,"background":28},77,true,{"title":192,"body":196,"image":210,"is_wide":190},[193],{"type":130,"text":194,"spans":195,"direction":87},"Enfants (+8 ans)",[],[197,203],{"type":90,"text":198,"spans":199,"direction":87},"Des séances les SAMEDI matin de 10h30 jusqu'à 12h00.",[200],{"start":201,"end":202,"type":160},16,22,{"type":90,"text":204,"spans":205,"direction":87},"De septembre à mi-juillet (sauf pendant les vacances scolaires).",[206,207,208],{"start":176,"end":177,"type":160},{"start":119,"end":179,"type":160},{"start":181,"end":209,"type":121},62,{"dimensions":211,"alt":5,"copyright":5,"url":212,"id":213,"edit":214},{"width":185,"height":143},"https:\u002F\u002Fimages.prismic.io\u002Faikido-traditionnel-cotiere\u002FagLVD6YofJOwHG27_WhatsAppImage2026-03-03at1.44.23PM-1-.jpeg?auto=format%2Ccompress&rect=0%2C47%2C1600%2C417&w=552&h=144","agLVD6YofJOwHG27",{"x":26,"y":215,"zoom":27,"background":28},47,{"title":217,"body":221,"image":225,"is_wide":40},[218],{"type":130,"text":219,"spans":220,"direction":87},"De tous âges",[],[222],{"type":90,"text":223,"spans":224,"direction":87},"Nos pratiquants ont entre 8 et 75 ans (à ce jour) ! Il n'y a pas d'âge pour débuter ou se perfectionner.",[],{"dimensions":226,"alt":5,"copyright":5,"url":227,"id":228,"edit":229},{"width":142,"height":143},"https:\u002F\u002Fimages.prismic.io\u002Faikido-traditionnel-cotiere\u002FagD25aYofJOwHC3F_060d7885-914a-4eb7-a278-fdf9d7473f13.png?auto=format%2Ccompress&rect=0%2C0%2C1600%2C960&w=240&h=144","agD25aYofJOwHC3F",{"x":26,"y":26,"zoom":27,"background":28},"bento$78c85834-d325-47b1-9a09-fd75e2dccee9","bento",{"variation":78,"version":79,"items":233,"primary":234,"id":258,"slice_type":259,"slice_label":5},[],{"title":235,"image":239,"icon":246,"punchline":247,"body":251,"cta":255},[236],{"type":115,"text":237,"spans":238,"direction":87},"L’Harmonie en Mouvement à Dagneux",[],{"dimensions":240,"alt":5,"copyright":5,"url":243,"id":244,"edit":245},{"width":241,"height":242},508,357,"https:\u002F\u002Fimages.prismic.io\u002Faikido-traditionnel-cotiere\u002FagLZLaYofJOwHG4l_bokkenr_t.png?auto=format,compress","agLZLaYofJOwHG4l",{"x":26,"y":26,"zoom":27,"background":28},"noto:martial-arts-uniform",[248],{"type":130,"text":249,"spans":250,"direction":87},"Découvrez un art martial authentique où la force devient souplesse, au cœur d'une ambiance familiale et passionnée.",[],[252],{"type":90,"text":253,"spans":254,"direction":87},"Et si votre plus belle victoire était celle que vous remportiez sur vous-même ? Rejoignez-nous sur le tatami pour transformer votre énergie et cultiver la sérénité.",[],{"link_type":64,"key":256,"url":99,"text":257},"23203e95-3868-4e04-b856-c2e2f1817d60","VENEZ ESSAYER : VOTRE PREMIER COURS EST OFFERT !","showcase$c21c1cae-fc21-41dc-b51e-47ec482364d0","showcase",{"variation":78,"version":79,"items":261,"primary":262,"id":357,"slice_type":45,"slice_label":5},[],{"title":263,"body":267,"focuses":271},[264],{"type":115,"text":265,"spans":266,"direction":87},"La pratique des 3 armes",[],[268],{"type":90,"text":269,"spans":270,"direction":87},"Découvrez notre pratique de l'Aïkido",[],[272,292,315,332],{"link":273},{"id":44,"type":45,"tags":274,"lang":14,"slug":47,"first_publication_date":48,"last_publication_date":49,"uid":50,"url":51,"data":275,"link_type":38,"key":291,"isBroken":40},[],{"title":276,"description":280,"cover":284},[277],{"type":84,"text":278,"spans":279,"direction":87},"L'aïkido",[],[281],{"type":90,"text":282,"spans":283,"direction":87},"Ici, pas de compétition. Nous cultivons le respect, l'entraide et la recherche de l'équilibre. Inspirés par l'enseignement de notre regretté Sensei Jimmy, nous perpétuons une tradition où chaque pratiquant progresse à son rythme.",[],{"dimensions":285,"alt":5,"copyright":5,"url":288,"id":289,"edit":290},{"width":286,"height":287},2816,1536,"https:\u002F\u002Fimages.prismic.io\u002Faikido-traditionnel-cotiere\u002FagMA6aYofJOwHHj0_Gemini_Generated_Image_ap8q70ap8q70ap8q.png?auto=format,compress","agMA6aYofJOwHHj0",{"x":26,"y":26,"zoom":27,"background":28},"9c2ca518-d39e-497f-897e-70313d700f7a",{"link":293},{"id":294,"type":45,"tags":295,"lang":14,"slug":296,"first_publication_date":297,"last_publication_date":298,"uid":299,"url":300,"data":301,"link_type":38,"key":314,"isBroken":40},"agLgwRAAACcATZZo",[],"la-pratique-des-3-armes","2026-05-12T08:41:52+0000","2026-06-23T13:42:54+0000","la-maitrise-des-3-armes","\u002Ffocus\u002Fla-maitrise-des-3-armes",{"title":302,"description":305,"cover":309},[303],{"type":84,"text":265,"spans":304,"direction":87},[],[306],{"type":90,"text":307,"spans":308,"direction":87},"Contrairement à une pratique purement sportive, nous enseignons l'Aïkido dans sa globalité. Vous apprendrez le maniement du Bokken (sabre en bois), du Jo (bâton) et du Tanto (couteau), piliers indispensables pour comprendre les déplacements et la précision des techniques à mains nues.",[],{"dimensions":310,"alt":5,"copyright":5,"url":311,"id":312,"edit":313},{"width":286,"height":287},"https:\u002F\u002Fimages.prismic.io\u002Faikido-traditionnel-cotiere\u002FagLnvKYofJOwHHC5_Gemini_Generated_Image_qp7a9eqp7a9eqp7a.png?auto=format,compress","agLnvKYofJOwHHC5",{"x":26,"y":26,"zoom":27,"background":28},"cb5ce3cf-536d-49fa-9c9a-bf4313dd1bf3",{"link":316},{"id":317,"type":45,"tags":318,"lang":14,"slug":319,"first_publication_date":320,"last_publication_date":320,"uid":319,"url":321,"data":322,"link_type":38,"key":331,"isBroken":40},"agMA-hAAACgATcz3",[],"une-ambiance-unique","2026-05-12T10:29:33+0000","\u002Ffocus\u002Fune-ambiance-unique",{"title":323,"description":327},[324],{"type":84,"text":325,"spans":326,"direction":87},"Une Ambiance Unique",[],[328],{"type":90,"text":329,"spans":330,"direction":87},"Le Dojo de la Côtière, c'est avant tout une \"famille\". On y vient pour la rigueur technique, on y reste pour la convivialité et la bienveillance des membres.",[],"f6217efd-8ead-44d3-90cc-94120c20a4cb",{"link"